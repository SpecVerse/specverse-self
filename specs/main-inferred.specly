    events:
      SpecificationCreated:
        description: "Specification was created"
        attributes:
          id: UUID required
          timestamp: DateTime required
          createdBy: UUID required
          version: Integer default=1

      SpecificationUpdated:
        description: "Specification was updated"
        attributes:
          id: UUID required
          changedFields: Array required
          previousValues: Object optional
          newValues: Object required
          timestamp: DateTime required
          updatedBy: UUID required
          version: Integer required

      SpecificationDeleted:
        description: "Specification was deleted"
        attributes:
          id: UUID required
          deletedBy: UUID required
          timestamp: DateTime required
          soft: Boolean default=true
          reason: String optional

      ComponentsAddedToSpecification:
        description: "components was added to Specification"
        attributes:
          specificationId: UUID required
          componentsId: UUID required
          relationshipType: String default=hasMany
          timestamp: DateTime required

      ComponentsRemovedFromSpecification:
        description: "components was removed from Specification"
        attributes:
          specificationId: UUID required
          componentsId: UUID required
          relationshipType: String default=hasMany
          timestamp: DateTime required

      DeploymentsAddedToSpecification:
        description: "deployments was added to Specification"
        attributes:
          specificationId: UUID required
          deploymentsId: UUID required
          relationshipType: String default=hasMany
          timestamp: DateTime required

      DeploymentsRemovedFromSpecification:
        description: "deployments was removed from Specification"
        attributes:
          specificationId: UUID required
          deploymentsId: UUID required
          relationshipType: String default=hasMany
          timestamp: DateTime required

      ManifestsAddedToSpecification:
        description: "manifests was added to Specification"
        attributes:
          specificationId: UUID required
          manifestsId: UUID required
          relationshipType: String default=hasMany
          timestamp: DateTime required

      ManifestsRemovedFromSpecification:
        description: "manifests was removed from Specification"
        attributes:
          specificationId: UUID required
          manifestsId: UUID required
          relationshipType: String default=hasMany
          timestamp: DateTime required

      ComponentAddedToSpecification:
        description: "Component was added to Specification"
        attributes:
          specificationId: UUID required
          componentId: UUID required
          relationshipType: String default=hasMany
          addedBy: UUID required
          timestamp: DateTime required

      ComponentRemovedFromSpecification:
        description: "Component was removed from Specification"
        attributes:
          id: UUID required
          specificationId: UUID required
          specificationName: String optional
          removedBy: UUID required
          timestamp: DateTime required
          reason: String optional

      DeploymentAddedToSpecification:
        description: "Deployment was added to Specification"
        attributes:
          specificationId: UUID required
          deploymentId: UUID required
          relationshipType: String default=hasMany
          addedBy: UUID required
          timestamp: DateTime required

      DeploymentRemovedFromSpecification:
        description: "Deployment was removed from Specification"
        attributes:
          id: UUID required
          specificationId: UUID required
          specificationName: String optional
          removedBy: UUID required
          timestamp: DateTime required
          reason: String optional

      ManifestAddedToSpecification:
        description: "Manifest was added to Specification"
        attributes:
          specificationId: UUID required
          manifestId: UUID required
          relationshipType: String default=hasMany
          addedBy: UUID required
          timestamp: DateTime required

      ManifestRemovedFromSpecification:
        description: "Manifest was removed from Specification"
        attributes:
          id: UUID required
          specificationId: UUID required
          specificationName: String optional
          removedBy: UUID required
          timestamp: DateTime required
          reason: String optional

      SpecificationProcessingStarted:
        description: "Specification business processing started"
        attributes:
          id: UUID required
          processType: String required
          processId: UUID required
          processParameters: Object optional
          startedBy: UUID required
          timestamp: DateTime required
          estimatedDuration: Integer optional

      SpecificationProcessingCompleted:
        description: "Specification business processing completed"
        attributes:
          id: UUID required
          processType: String required
          processId: UUID required
          processingResults: Object required
          duration: Integer required
