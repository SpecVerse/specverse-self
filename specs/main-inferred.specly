          validatedBy: UUID required
          severity: String default=error

      AIWorkflowValidationPassed:
        description: "AIWorkflow validation passed"
        attributes:
          id: UUID optional
          entityData: Object required
          validationType: String required
          rulesChecked: String optional
          timestamp: DateTime required
          validatedBy: UUID required


