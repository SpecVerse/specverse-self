      SystemDashboardView:
        type: dashboard
        model: [Specification, Import, Export, Primitive, Operation, EntityModule, EntityRegistry, ConventionGrammar, InferenceRule, DiagramPlugin, VSCodeExtension, MCPServer, AIOrchestrator]
        description: "System-wide dashboard showing overview of all main entities"
        subscribes_to:
          - SpecificationCreated
          - SpecificationUpdated
          - SpecificationDeleted
          - ImportCreated
          - ImportUpdated
          - ImportDeleted
          - ExportCreated
          - ExportUpdated
          - ExportDeleted
          - PrimitiveCreated
          - PrimitiveUpdated
          - PrimitiveDeleted
          - OperationCreated
          - OperationUpdated
          - OperationDeleted
          - EntityModuleCreated
          - EntityModuleUpdated
          - EntityModuleDeleted
          - EntityRegistryCreated
          - EntityRegistryUpdated
          - EntityRegistryDeleted
          - ConventionGrammarCreated
          - ConventionGrammarUpdated
          - ConventionGrammarDeleted
          - InferenceRuleCreated
          - InferenceRuleUpdated
          - InferenceRuleDeleted
          - DiagramPluginCreated
          - DiagramPluginUpdated
          - DiagramPluginDeleted
          - VSCodeExtensionCreated
          - VSCodeExtensionUpdated
          - VSCodeExtensionDeleted
          - MCPServerCreated
          - MCPServerUpdated
          - MCPServerDeleted
          - AIOrchestratorCreated
          - AIOrchestratorUpdated
          - AIOrchestratorDeleted
        uiComponents:
          specificationCard:
            type: card
            properties:
              variant: metric
              showTrend: true
              metric: specification
              model: Specification
          importCard:
            type: card
            properties:
              variant: metric
              showTrend: true
              metric: import
              model: Specification
          exportCard:
            type: card
            properties:
              variant: metric
              showTrend: true
              metric: export
              model: Specification
          trendChart:
            type: chart
            properties:
              responsive: true
              showLegend: true
              chartType: trend
              model: Specification
          distributionChart:
            type: chart
            properties:
              responsive: true
              showLegend: true
              chartType: distribution
              model: Specification
          summaryTable:
            type: table
            properties:
              compact: true
              pagination: true
              model: Specification