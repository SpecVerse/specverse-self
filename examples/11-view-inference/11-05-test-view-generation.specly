components:
  TestApp:
    version: "3.4.0"
    models:
      Product:
        attributes:
          name: String required
          description: Text
          price: Money required
          category: String values=[electronics,clothing,books]
          inStock: Boolean default=true
          releaseDate: DateTime
        relationships:
          supplier: belongsTo Supplier
          reviews: hasMany Review

      Supplier:
        attributes:
          companyName: String required
          email: Email required unique
          phone: Phone
          website: URL
        relationships:
          products: hasMany Product

      Review:
        attributes:
          rating: Integer min=1 max=5
          comment: Text
          createdAt: DateTime
        relationships:
          product: belongsTo Product
          author: belongsTo User

      User:
        attributes:
          username: String required unique
          email: Email required unique
          password: String required
          active: Boolean default=true
        relationships:
          reviews: hasMany Review

    # NOTE: No views defined - they will be auto-generated!
    # The ViewGenerator will create:
    # - ProductListView (with searchBar, filterPanel, table, pagination)
    # - ProductDetailView (with header, card, actions)
    # - ProductFormView (with header, form, actions)
    # - Similar views for Supplier, Review, User
