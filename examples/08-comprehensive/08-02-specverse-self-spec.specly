# SpecVerse Self-Specification
# The SpecVerse specification language, specified in itself.
# "Define Once, Implement Anywhere™" — including defining itself.
#
# Domain areas:
#   1. Specification Language (what users write)
#   2. Convention System (shorthand expansion)
#   3. Inference Engine (architecture generation)
#   4. Entity Module System (extensible build architecture)
#   5. Formal Verification (Quint behavioural specs)
#   6. Realization System (code generation)
#   7. Diagram Engine (visualization)
#   8. AI Support (MCP server, orchestrator)

components:

  # ═══════════════════════════════════════════════════════════════════
  # 1. SPECIFICATION LANGUAGE — What users write in .specly files
  # ═══════════════════════════════════════════════════════════════════

  SpecLanguage:
    version: "3.5.2"
    description: "The core specification language: components, models, controllers, services, events, views, deployments"

    models:

      Specification:
        description: "A .specly file — the top-level container for all SpecVerse definitions"
        attributes:
          id: UUID required unique
          filename: String required unique
          specVersion: String required
        relationships:
          components: hasMany Component
          deployments: hasMany Deployment
          manifests: hasMany Manifest

      # ─── Component Layer (WHAT) ─────────────────────────────────

      Component:
        description: "A named container grouping models, controllers, services, events, and views"
        attributes:
          id: UUID required unique
          name: String required unique
          version: String required
          description: String
          tags: "String[]"
        relationships:
          specification: belongsTo Specification
          imports: hasMany Import
          exports: hasMany Export
          models: hasMany Model
          controllers: hasMany Controller
          services: hasMany Service
          events: hasMany Event
          views: hasMany View

      Import:
        description: "An import declaration referencing types from another component or package"
        attributes:
          id: UUID required unique
          from: String required
          file: String
          package: String
          namespace: String
          version: String
          select: "String[]"

      Export:
        description: "An export declaration making types available to other components"
        attributes:
          id: UUID required unique
          capabilities: "String[]"

      # ─── Models ─────────────────────────────────────────────────

      Model:
        description: "A domain entity with attributes, relationships, lifecycles, and behaviours"
        attributes:
          id: UUID required unique
          name: String required unique
          description: String
          extends: String
        relationships:
          component: belongsTo Component
          attributes: hasMany Attribute
          relationships: hasMany Relationship
          lifecycles: hasMany Lifecycle
          behaviors: hasMany Operation
          profiles: hasMany Profile
        metadata:
          id: uuid
          audit: true

      Attribute:
        description: "A typed field on a model — convention syntax expands 'email: Email required unique' into this"
        attributes:
          id: UUID required unique
          name: String required
          attrType: String required
          required: Boolean default=false
          unique: Boolean default=false
          searchable: Boolean default=false
          verified: Boolean default=false
          defaultValue: String
          auto: String
        relationships:
          model: belongsTo Model

      Relationship:
        description: "A connection between models: hasMany, belongsTo, hasOne, manyToMany"
        attributes:
          id: UUID required unique
          name: String required
          relType: String required values=[hasMany, belongsTo, hasOne, manyToMany]
          target: String required
          eager: Boolean default=false
          cascade: String
        relationships:
          model: belongsTo Model

      Lifecycle:
        description: "A state machine defining valid transitions for a model"
        attributes:
          id: UUID required unique
          name: String required
          flow: String required
        relationships:
          model: belongsTo Model
          states: hasMany LifecycleState
          transitions: hasMany LifecycleTransition

      LifecycleState:
        description: "A named state within a lifecycle"
        attributes:
          id: UUID required unique
          name: String required
          isInitial: Boolean default=false
          isTerminal: Boolean default=false
        relationships:
          lifecycle: belongsTo Lifecycle

      LifecycleTransition:
        description: "A valid transition between lifecycle states"
        attributes:
          id: UUID required unique
          name: String required
          fromState: String required
          toState: String required
          action: String
        relationships:
          lifecycle: belongsTo Lifecycle

      Profile:
        description: "A set of additional attributes that can be attached to a model instance"
        attributes:
          id: UUID required unique
          name: String required unique
          description: String
        relationships:
          model: belongsTo Model

      Primitive:
        description: "A reusable custom type definition — 'ProductCode: String pattern=...'"
        attributes:
          id: UUID required unique
          name: String required unique
          baseType: String required
          description: String
          pattern: String
          isTypeAlias: Boolean default=true

      # ─── Operations (ExecutableProperties) ─────────────────────

      Operation:
        description: "A named executable unit — the universal shape for model behaviors, CURED operations, controller actions, and service operations. All resolve to ExecutableProperties in the schema."
        attributes:
          id: UUID required unique
          name: String required
          description: String
          returns: String
          requires: String
          ensures: String
        relationships:
          parameters: hasMany Attribute
          publishes: hasMany Event
          steps: hasMany Step

      Step:
        description: "An ordered unit within an operation — oneOf [String, Operation]. Simple steps are convention strings ('Validate cart', 'tax = subtotal * taxRate'). Complex steps are full inline Operations. Convention processors expand string steps when matching grammars exist."
        attributes:
          id: UUID required unique
          ordinal: Integer required
          instruction: String
        relationships:
          operation: belongsTo Operation
          expandedOperation: hasOne Operation

      # ─── Controllers (CURED) ────────────────────────────────────

      Controller:
        description: "API controller with CURED operations — generated by inference from models"
        attributes:
          id: UUID required unique
          name: String required unique
          pattern: String required values=[StandardCURED, ParentScopedCURED]
          parentModel: String
          hasAssociationOps: Boolean default=false
        relationships:
          component: belongsTo Component
          model: belongsTo Model
          curedOperations: hasMany Operation
          actions: hasMany Operation
          subscriptions: hasMany Event

      # ─── Services ───────────────────────────────────────────────

      Service:
        description: "Business logic service — generated by inference for lifecycle, relationship, and integration patterns"
        attributes:
          id: UUID required unique
          name: String required unique
          pattern: String required values=[LifecycleService, RelationshipService, IntegrationService]
        relationships:
          component: belongsTo Component
          model: belongsTo Model
          operations: hasMany Operation
          subscriptions: hasMany Event
        lifecycles:
          servicePattern:
            flow: active -> deprecated

      # ─── Events ─────────────────────────────────────────────────

      Event:
        description: "Domain event with typed payload — generated by inference for CRUD, lifecycle, relationship, and validation patterns"
        attributes:
          id: UUID required unique
          name: String required unique
          description: String
          pattern: String required values=[StandardEvents, LifecycleEvents, RelationshipEvents, ValidationEvents, ProfileEvents]
          modelName: String required
          version: Integer required default=1
        relationships:
          component: belongsTo Component
          attributes: hasMany Attribute
          previousVersions: hasMany EventVersion

      EventVersion:
        description: "A previous version of an event schema for compatibility tracking"
        attributes:
          id: UUID required unique
          version: Integer required
          compatibility: String required values=[backward, forward, full, none] default=none
          deprecated: Boolean default=false
          deprecationMessage: String
        relationships:
          event: belongsTo Event

      # ─── Views ──────────────────────────────────────────────────

      View:
        description: "UI specification — page, list, detail, form, dashboard, or custom views generated from models"
        attributes:
          id: UUID required unique
          name: String required unique
          viewType: String required
          primaryModel: String required
          tags: "String[]"
          export: Boolean default=false
          hasProfileSupport: Boolean default=false
        relationships:
          component: belongsTo Component
          layout: hasOne Layout
          uiComponents: hasMany UIComponent
          subscriptions: hasMany Event

      Layout:
        description: "View layout definition — standard or custom arrangement of UI components"
        attributes:
          id: UUID required unique
          layoutType: String required
        relationships:
          view: belongsTo View

      UIComponent:
        description: "An atomic UI component within a view — one of 49 types (input, select, table, etc.)"
        attributes:
          id: UUID required unique
          componentType: String required
          name: String required
        relationships:
          view: belongsTo View

      # ─── Deployment Layer (WHERE) ────────────────────────────────

      Deployment:
        description: "Logical deployment configuration mapping components to instances"
        attributes:
          id: UUID required unique
          name: String required unique
          environment: String required values=[development, staging, production]
        relationships:
          specification: belongsTo Specification
          instances: hasMany DeploymentInstance
          channels: hasMany CommunicationChannel

      DeploymentInstance:
        description: "A deployed instance of a controller, service, or view"
        attributes:
          id: UUID required unique
          name: String required
          category: String required values=[controller, service, view, storage, security, infrastructure, monitoring]
          scale: Integer default=1
        relationships:
          deployment: belongsTo Deployment

      CommunicationChannel:
        description: "A message bus or communication link between deployment instances"
        attributes:
          id: UUID required unique
          name: String required
          channelType: String required values=[pubsub, request-reply, stream]
        relationships:
          deployment: belongsTo Deployment

      # ─── Manifest Layer (HOW) ────────────────────────────────────

      Manifest:
        description: "Implementation manifest mapping deployment instances to concrete technologies"
        attributes:
          id: UUID required unique
          name: String required unique
          specVersion: String required
        relationships:
          specification: belongsTo Specification
          instanceFactories: hasMany InstanceFactory
          capabilityMappings: hasMany CapabilityMapping

      InstanceFactory:
        description: "A reusable technology specification — Prisma, Fastify, NestJS, React, etc."
        attributes:
          id: UUID required unique
          name: String required unique
          version: String required
          category: String required values=[backend, frontend, storage, infrastructure]
          technology: String required
        relationships:
          manifest: belongsTo Manifest

      CapabilityMapping:
        description: "Maps a capability pattern to an instance factory: storage.database -> PrismaPostgres"
        attributes:
          id: UUID required unique
          capability: String required
          factoryName: String required
        relationships:
          manifest: belongsTo Manifest
          instanceFactory: belongsTo InstanceFactory

    constraints:
      - "models must have attributes"
      - "models must have id"
      - "model names must be unique"
      - "model relationship targets must exist"

  # ═══════════════════════════════════════════════════════════════════
  # 2. BUILD SYSTEM — Entity modules, conventions, inference, schema
  # ═══════════════════════════════════════════════════════════════════

  BuildSystem:
    version: "3.5.2"
    description: "The entity module system, convention engine, inference pipeline, and schema composition"

    models:

      # ─── Entity Module System ───────────────────────────────────

      EntityModule:
        description: "A self-contained unit of specification capability with up to 8 facets"
        attributes:
          id: UUID required unique
          name: String required unique
          moduleType: String required values=[core, extension]
          version: String required
          hasFacetSchema: Boolean default=true
          hasFacetConventions: Boolean default=true
          hasFacetInference: Boolean default=false
          hasFacetBehaviour: Boolean default=true
          hasFacetGenerators: Boolean default=false
          hasFacetDiagrams: Boolean default=false
          hasFacetDocs: Boolean default=true
          hasFacetTests: Boolean default=true
        lifecycles:
          registration:
            flow: discovered -> registered -> active -> deprecated

      EntityRegistry:
        description: "Singleton registry holding all entity modules in topological dependency order"
        attributes:
          id: UUID required unique
          moduleCount: Integer
          usesKahnsAlgorithm: Boolean default=true
        behaviors:
          bootstrap:
            description: "Register all core and extension entity modules"
            ensures:
              - "All 9 modules registered"
              - "Dependency order resolved"
          getConventionProcessors:
            description: "Return convention processors from all registered modules"
            returns: "Map<string, EntityConventionProcessor>"

      # ─── Convention System ──────────────────────────────────────

      ConventionGrammar:
        description: "Defines human-readable convention patterns that expand into formal Quint specifications"
        attributes:
          id: UUID required unique
          domain: String required default=quint
          entityType: String required unique
          conventionCount: Integer

      ConventionPattern:
        description: "A single pattern-to-template mapping: '{entities} must have attributes' -> Quint invariant"
        attributes:
          id: UUID required unique
          name: String required unique
          pattern: String required
          expandsTo: String required values=[quint:invariant, quint:rule, quint:temporal]
          description: String
          templateName: String required
          templateBody: String required
        relationships:
          grammar: belongsTo ConventionGrammar

      # ─── Inference Engine ───────────────────────────────────────

      InferenceRule:
        description: "A JSON-based rule that pattern-matches models and generates architecture"
        attributes:
          id: UUID required unique
          ruleId: String required unique
          description: String required
          pattern: String required
          priority: Integer required default=100
          category: String required values=[controllers, services, events, views, deployment]
          conditionExpression: String
          isActive: Boolean default=true
        lifecycles:
          ruleStatus:
            flow: active -> disabled -> active

      RuleTemplate:
        description: "A Handlebars template that generates YAML output from matched model context"
        attributes:
          id: UUID required unique
          templateType: String required values=[yaml, json]
          content: String required
        relationships:
          rule: belongsTo InferenceRule

      # ─── Formal Verification ────────────────────────────────────

      BehaviourSpec:
        description: "Quint formal specification defining invariants and rules for an entity type"
        attributes:
          id: UUID required unique
          entityType: String required
          invariantCount: Integer
          ruleCount: Integer
          verificationStatus: String values=[untested, typechecked, verified]
        relationships:
          module: belongsTo EntityModule

      Invariant:
        description: "A Quint val that must hold for all valid specifications"
        attributes:
          id: UUID required unique
          name: String required unique
          description: String required
          quintExpression: String required
          category: String required values=[structural, relationship, lifecycle, inference, deprecated]
        relationships:
          spec: belongsTo BehaviourSpec

      # ─── Schema System ─────────────────────────────────────────

      SchemaFragment:
        description: "A JSON Schema fragment providing $defs for one entity type or shared concern"
        attributes:
          id: UUID required unique
          schemaId: String required unique
          description: String
          defsCount: Integer required
          fragmentType: String required values=[primitives, entity, root, manifests, instance-factories]
        relationships:
          module: belongsTo EntityModule

      # ─── Diagram Engine ─────────────────────────────────────────

      DiagramPlugin:
        description: "A Mermaid diagram generator registered by entity modules"
        attributes:
          id: UUID required unique
          diagramType: String required unique values=[er, class, event-flow, lifecycle, architecture, deployment, manifest]
          description: String

      # ─── Realization System ─────────────────────────────────────

      CodeTemplate:
        description: "A TypeScript template generator that produces framework-specific code from specs"
        attributes:
          id: UUID required unique
          name: String required unique
          templateType: String required values=[schema, services, routes, hooks, api-client]
          technology: String required
          basePath: String required
        relationships:
          entityModule: belongsTo EntityModule

    constraints:
      - "models must have attributes"
      - "model names must be unique"
      - "deprecated patterns never generated"

  # ═══════════════════════════════════════════════════════════════════
  # 3. AI SUPPORT — MCP server, orchestrator, prompts
  # ═══════════════════════════════════════════════════════════════════

  AISupport:
    version: "3.5.2"
    description: "MCP server for AI assistant integration, AI orchestrator for multi-step workflows"

    models:

      MCPServer:
        description: "Model Context Protocol server exposing SpecVerse capabilities to AI assistants"
        attributes:
          id: UUID required unique
          name: String required default="specverse-dynamic-cli"
          mode: String required values=[local, web, extension, enterprise]
        relationships:
          resources: hasMany MCPResource
          tools: hasMany MCPTool

      MCPResource:
        description: "A read-only resource served by the MCP server (schema, conventions, entity metadata)"
        attributes:
          id: UUID required unique
          uri: String required unique
          name: String required
          description: String
          mimeType: String required default="application/json"
        relationships:
          server: belongsTo MCPServer

      MCPTool:
        description: "An executable tool exposed by the MCP server (CLI proxy or entity module tool)"
        attributes:
          id: UUID required unique
          name: String required unique
          description: String required
          isEntityModuleTool: Boolean default=false
        relationships:
          server: belongsTo MCPServer

      AIOrchestrator:
        description: "Coordinates multi-step AI workflows: analyse, create, infer, materialise, realize"
        attributes:
          id: UUID required unique
          name: String required
          providerType: String required values=[openai, anthropic, interactive]
        relationships:
          workflows: hasMany AIWorkflow
        lifecycles:
          workflow:
            flow: idle -> analysing -> creating -> inferring -> materialising -> realizing -> complete

      AIWorkflow:
        description: "A defined multi-step AI workflow with conditional logic and chaining"
        attributes:
          id: UUID required unique
          name: String required unique
          description: String
          stepCount: Integer
        relationships:
          orchestrator: belongsTo AIOrchestrator

    constraints:
      - "model names must be unique"

  # ═══════════════════════════════════════════════════════════════════
  # 4. CLI — Command-line interface
  # ═══════════════════════════════════════════════════════════════════

  CLI:
    version: "3.5.2"
    description: "The SpecVerse command-line interface"

    commands:
      specverse:
        description: "SpecVerse specification language CLI"
        subcommands:
          validate:
            description: "Validate a .specly specification"
            arguments:
              file:
                type: FilePath
                required: true
                positional: true
            flags:
              --json:
                type: Boolean
                default: false
                description: "Output results in JSON format"
              --strict:
                type: Boolean
                default: false
                description: "Enable strict validation mode"
            returns: ValidationResult
            exitCodes:
              0: Valid
              1: Errors found
          infer:
            description: "Generate architecture from models via inference engine"
            arguments:
              file:
                type: FilePath
                required: true
                positional: true
            flags:
              --output:
                type: FilePath
                alias: "-o"
                description: "Output file path"
              --deployment:
                type: Boolean
                default: false
                description: "Generate deployment specification"
              --verbose:
                type: Boolean
                alias: "-v"
                default: false
                description: "Show detailed inference process"
            returns: InferredSpecification
          realize:
            description: "Generate production code from specification"
            arguments:
              type:
                type: String
                required: true
                positional: true
                description: "Code type: orm, services, routes, cli, all"
              file:
                type: FilePath
                required: true
                positional: true
            flags:
              --output:
                type: FilePath
                alias: "-o"
                description: "Output directory"
              --manifest:
                type: FilePath
                alias: "-m"
                description: "Implementation manifest file"
            returns: GeneratedCode
          init:
            description: "Initialize a new SpecVerse project"
            arguments:
              name:
                type: String
                positional: true
            flags:
              --template:
                type: String
                default: "default"
                description: "Template to use"
              --list:
                type: Boolean
                default: false
                description: "List available templates"
          gen:
            description: "Generate outputs from specification"
            subcommands:
              diagrams:
                description: "Generate Mermaid diagrams (ER, lifecycle, architecture, etc.)"
                arguments:
                  file:
                    type: FilePath
                    required: true
                    positional: true
                flags:
                  --type:
                    type: String
                    default: "all"
                    description: "Diagram type: er, class, event-flow, lifecycle, architecture, deployment, manifest, all"
                  --output:
                    type: FilePath
                    alias: "-o"
                    description: "Output directory"
              docs:
                description: "Generate documentation from specification"
                arguments:
                  file:
                    type: FilePath
                    required: true
                    positional: true
                flags:
                  --format:
                    type: String
                    default: "markdown"
                    description: "Output format: markdown, html"
                  --output:
                    type: FilePath
                    alias: "-o"
                    description: "Output file path"
              uml:
                description: "Generate UML diagrams"
                arguments:
                  file:
                    type: FilePath
                    required: true
                    positional: true
                flags:
                  --type:
                    type: String
                    default: "all"
                    description: "UML type: class, sequence, activity, all"
          dev:
            description: "Development workflow commands"
            subcommands:
              format:
                description: "Format a .specly file with consistent styling"
                arguments:
                  file:
                    type: FilePath
                    required: true
                    positional: true
                flags:
                  --write:
                    type: Boolean
                    alias: "-w"
                    default: false
                    description: "Write formatted output back to file"
              watch:
                description: "Watch .specly files and re-validate on change"
                arguments:
                  file:
                    type: FilePath
                    required: true
                    positional: true
              quick:
                description: "Quick validation (schema-only, skip semantic checks)"
                arguments:
                  file:
                    type: FilePath
                    required: true
                    positional: true
          cache:
            description: "Manage import cache"
            flags:
              --stats:
                type: Boolean
                default: false
                description: "Show cache statistics"
              --list:
                type: Boolean
                default: false
                description: "List cached items"
              --clear:
                type: Boolean
                default: false
                description: "Clear all cached items"
          ai:
            description: "AI prompt building and suggestion commands"
            subcommands:
              docs:
                description: "Generate AI documentation prompts from specification"
                arguments:
                  file:
                    type: FilePath
                    required: true
                    positional: true
                flags:
                  --output:
                    type: FilePath
                    alias: "-o"
                    description: "Output file path"
                  --config:
                    type: FilePath
                    description: "Configuration file with requirements, scale, etc."
              suggest:
                description: "Get AI suggestions for improving a specification"
                arguments:
                  file:
                    type: FilePath
                    required: true
                    positional: true
              template:
                description: "Generate AI implementation templates"
                arguments:
                  operation:
                    type: String
                    required: true
                    positional: true
                flags:
                  --output:
                    type: FilePath
                    alias: "-o"
                    description: "Output file path"
                  --config:
                    type: FilePath
                    description: "Configuration file"

deployments: {}
