{
  "name": "speclanguage-backend",
  "version": "3.5.2",
  "description": "Backend API for SpecLanguage",
  "private": true,
  "type": "module",
  "scripts": {
    "cli": "tsx src/cli/index.ts",
    "dev": "tsx watch src/main.ts",
    "dev:debug": "tsx watch --inspect src/main.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/main.js",
    "db:setup": "prisma generate && prisma db push",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@specverse/types": "file:../../../../specverse-engines/packages/types",
    "@specverse/engine-entities": "file:../../../../specverse-engines/packages/entities",
    "@specverse/engine-parser": "file:../../../../specverse-engines/packages/parser",
    "@specverse/engine-inference": "file:../../../../specverse-engines/packages/inference",
    "@specverse/engine-realize": "file:../../../../specverse-engines/packages/realize",
    "@specverse/engine-generators": "file:../../../../specverse-engines/packages/generators",
    "@specverse/engine-ai": "file:../../../../specverse-engines/packages/ai",
    "commander": "^12.0.0",
    "@prisma/client": "^5.7.0",
    "fastify": "^4.25.0",
    "@fastify/cors": "^8.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "zod": "^3.22.0",
    "dotenv": "^16.3.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "prisma": "^5.7.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}